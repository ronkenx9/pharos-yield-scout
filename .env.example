# Pharos Atlantic testnet RPC
PHAROS_RPC_URL=https://atlantic.dplabs-internal.com

# Optional: include clearly-labelled SIMULATED reference pools when no live
# Pharos pools are indexed on DeFiLlama. Set to false to show live data only.
INCLUDE_SIMULATED_POOLS=true

# Optional: comma-separated token addresses to treat as deployed positions
# (LP/vault/lending/staked receipt tokens), excluded from idle capital.
DEPLOYED_TOKEN_ADDRESSES=
